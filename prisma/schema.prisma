generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SlPlayer {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  country      String    @default("MAS")
  birthDate    DateTime?
  height       String?
  playStyle    String?
  category     String    // MS, WS, MD, WD, XD
  bwfId        String?   @unique
  imageUrl     String?
  worldRanking Int?
  bio          String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  externalId   String?   @unique  // playerid from badmintonstatistics.net
  matchCount   Int       @default(0)

  matchesAsPlayer1 SlMatch[] @relation("Player1Matches")
  matchesAsPlayer2 SlMatch[] @relation("Player2Matches")
  teamEventSquads  SlTeamEventSquad[]

  @@index([country])
  @@index([worldRanking])
  @@index([matchCount])
  @@map("sl_player")
}

model SlTournament {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  level     String    // Super 1000, Super 750, Super 500, Super 300, Super 100, Major
  location  String?
  country   String?
  startDate DateTime
  endDate   DateTime?
  year      Int
  createdAt DateTime  @default(now())

  externalId    String?   @unique  // GUID from badmintonstatistics.net
  lastScrapedAt DateTime?

  matches SlMatch[]

  @@index([year])
  @@index([level])
  @@index([externalId])
  @@map("sl_tournament")
}

model SlMatch {
  id             String       @id @default(cuid())
  tournamentId   String
  tournament     SlTournament @relation(fields: [tournamentId], references: [id])
  round          String       // F, SF, QF, R16, R32, R64, Group
  date           DateTime
  category       String       // MS, WS, MD, WD, XD
  player1Id      String
  player1        SlPlayer     @relation("Player1Matches", fields: [player1Id], references: [id])
  player2Id      String
  player2        SlPlayer     @relation("Player2Matches", fields: [player2Id], references: [id])
  player1Partner String?
  player2Partner String?
  score          String       // "21-19 21-17" or "21-19 18-21 21-15"
  winnerId       String?
  walkover       Boolean      @default(false)
  durationMin    Int?
  createdAt      DateTime     @default(now())

  @@index([player1Id, date])
  @@index([player2Id, date])
  @@index([tournamentId])
  @@map("sl_match")
}

model SlExternalStat {
  id         String   @id @default(cuid())
  source     String   // "HOF" | "Reports"
  reportName String
  category   String   @default("%")
  level      String   @default("worldtour")
  year       String   @default("-1")
  headers    String[]
  rows       Json     // array of {cells: string[]}
  scrapedAt  DateTime @default(now())

  @@unique([reportName, category, level, year])
  @@map("sl_external_stat")
}

// One row per edition of a team event (Thomas Cup 2022, Uber Cup 2022, etc.).
model SlTeamEvent {
  id        String   @id @default(cuid())
  type      String   // THOMAS | UBER | SUDIRMAN
  year      Int
  startDate DateTime?
  endDate   DateTime?
  host      String?
  createdAt DateTime @default(now())

  results   SlTeamEventResult[]
  squads    SlTeamEventSquad[]

  @@unique([type, year])
  @@index([type])
  @@index([year])
  @@map("sl_team_event")
}

// One row per country that participated in a given team event. finish is
// hand-entered from historical records; teamScore is recomputed from match
// data.
model SlTeamEventResult {
  id          String   @id @default(cuid())
  teamEventId String
  country     String   // 3-letter code (MAS, CHN, INA, ...)
  finish      String   // CHAMPION | RUNNER_UP | SEMI_FINAL | QUARTER_FINAL | GROUP_STAGE | DID_NOT_QUALIFY
  teamScore   Float?   // computed via scripts/compute-team-scores.ts
  computedAt  DateTime?

  TeamEvent   SlTeamEvent @relation(fields: [teamEventId], references: [id], onDelete: Cascade)

  @@unique([teamEventId, country])
  @@index([country])
  @@map("sl_team_event_result")
}

// One row per player that contributed to a country's team score at a
// given event edition. Populated by scripts/compute-team-scores.ts so the
// UI can show "these 4 players carried China's Thomas Cup 2024 score".
model SlTeamEventSquad {
  id          String   @id @default(cuid())
  teamEventId String
  country     String
  playerId    String
  category    String   // MS | WS | MD | WD | XD
  slotRank    Int      // 1 = top player in category, 2 = second, ...
  score       Float    // contribution to team score

  TeamEvent   SlTeamEvent @relation(fields: [teamEventId], references: [id], onDelete: Cascade)
  Player      SlPlayer    @relation(fields: [playerId], references: [id])

  @@unique([teamEventId, country, category, slotRank])
  @@index([teamEventId, country])
  @@index([playerId])
  @@map("sl_team_event_squad")
}

model SlSyncLog {
  id                String    @id @default(cuid())
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  mode              String    // "full" | "incremental"
  status            String    // "running" | "success" | "error"
  yearsRange        String?   // e.g. "1990-2026"
  tournamentsTotal  Int       @default(0)
  tournamentsNew    Int       @default(0)
  matchesAdded      Int       @default(0)
  playersDiscovered Int       @default(0)
  errorMessage      String?

  @@map("sl_sync_log")
}
